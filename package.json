{
	"name": "browser-fps",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"lint": "biome check src",
		"format": "biome format --write src",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
