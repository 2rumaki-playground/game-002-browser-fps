		"test:e2e:ui": "playwright test --ui"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.13",
		"@playwright/test": "^1.58.1",
		"@vitest/coverage-v8": "^4.0.18",
		"typescript": "~5.9.3",
		"vite": "^7.2.4",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@babylonjs/core": "^7.52.5"
	},
	"pnpm": {
		"overrides": {
			"rollup": "^4.59.0"
		},
		"onlyBuiltDependencies": ["esbuild"]
	}
}
